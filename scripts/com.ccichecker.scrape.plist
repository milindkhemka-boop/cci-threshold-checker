<?xml version="1.0" encoding="UTF-8"?>
<!--
  macOS launchd job: scrape RBI reference rates once a day at 18:30.
  If the Mac is asleep/off at that time, launchd runs it on next wake.

  Install:
    1. Edit the two __PROJECT_DIR__ paths below to the absolute path of this
       project, e.g. /Users/MilindKhemka/Desktop/Claude Code/cci-threshold-checker
    2. cp scripts/com.ccichecker.scrape.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.ccichecker.scrape.plist
    4. (run once now)  launchctl start com.ccichecker.scrape

  Uninstall:
       launchctl unload ~/Library/LaunchAgents/com.ccichecker.scrape.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ccichecker.scrape</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>__PROJECT_DIR__/scripts/scrape_rates.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>18</integer>
        <key>Minute</key><integer>30</integer>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/data/scrape.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/data/scrape.log</string>
</dict>
</plist>
